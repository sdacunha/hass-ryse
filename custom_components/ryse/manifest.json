{
  "domain": "ryse",
  "name": "RYSE SmartShade",
  "description": "RYSE SmartShade Bluetooth integration for Home Assistant",
  "version": "1.0.44",
  "documentation": "https://github.com/sdacunha/hass-ryse",
  "dependencies": [
    "bluetooth",
    "bluetooth_adapters"
  ],
  "integration_type": "device",
  "codeowners": [
    "@sdacunha"
  ],
  "requirements": [
    "bleak>=0.20.0",
    "bleak-retry-connector>=3.0.0"
  ],
  "iot_class": "local_push",
  "config_flow": true,
  "bluetooth": [
    {
      "local_name": "RZSS*",
      "manufacturer_id": 1033,
      "connectable": false
    }
  ],
  "supported_platforms": [
    "cover",
    "sensor"
  ],
  "loggers": [
    "custom_components.ryse"
  ]
}
